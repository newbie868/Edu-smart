rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is logged in
    function loggedIn() {
      return request.auth != null;
    }
    
    // Retrieve user document from the global user_mappings collection safely
    function getUserData() {
      let path = /databases/$(database)/documents/user_mappings/$(request.auth.uid);
      return exists(path) ? get(path).data : {"role": "", "schoolId": "", "isActive": false};
    }
    
    // Check if user has Super Admin role
    function isSuperAdmin() {
      return loggedIn() && getUserData().role == 'super_admin' && getUserData().isActive == true;
    }
    
    // Verify if user belongs to the specified school and is active
    function isSchoolMember(schoolId) {
      return loggedIn() && 
             getUserData().schoolId == schoolId && 
             getUserData().isActive == true;
    }

    // Check if user is a principal of the specified school and is active
    function isPrincipalOf(schoolId) {
      return loggedIn() && 
             getUserData().role == 'principal' && 
             getUserData().schoolId == schoolId && 
             getUserData().isActive == true;
    }

    // --- USER MAPPINGS COLLECTION ---
    match /user_mappings/{uid} {
      allow read: if loggedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow write: if isSuperAdmin() || (
        loggedIn() && 
        request.auth.uid == uid &&
        get(/databases/$(database)/documents/users/$(request.resource.data.get('docId', ''))).data.get('email', '') == request.auth.token.email &&
        request.resource.data.get('role', '') == get(/databases/$(database)/documents/users/$(request.resource.data.get('docId', ''))).data.get('role', '') &&
        request.resource.data.get('schoolId', null) == get(/databases/$(database)/documents/users/$(request.resource.data.get('docId', ''))).data.get('schoolId', null) &&
        request.resource.data.get('isActive', false) == get(/databases/$(database)/documents/users/$(request.resource.data.get('docId', ''))).data.get('isActive', false)
      );
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      // Users can read their own profile (by UID or email during login), Super Admin can read all, and members of the same school can read profiles in their tenant.
      // Firestore queries require simple property access (e.g. resource.data.uid) without function calls for query validation to succeed.
      allow read: if loggedIn() && (
        resource.data.uid == request.auth.uid || 
        resource.data.email == request.auth.token.email ||
        isSuperAdmin() || 
        (resource != null && getUserData().schoolId == resource.data.schoolId)
      );
      // Only Super Admins and the Principal of the same school can create user profiles.
      allow create: if isSuperAdmin() || (
        loggedIn() && 
        isPrincipalOf(request.resource.data.get('schoolId', '')) &&
        (request.resource.data.get('role', '') == 'teacher' || request.resource.data.get('role', '') == 'student' || request.resource.data.get('role', '') == 'parent')
      );
      // Only Super Admins, the Principal of the same school, or the user themselves (for UID binding / minor updates) can update profiles.
      allow update: if isSuperAdmin() || (
        loggedIn() && 
        (
          // Case 1: Standard update by already-bound user
          (resource.data.uid == request.auth.uid &&
           request.resource.data.uid == request.auth.uid &&
           request.resource.data.role == resource.data.role && 
           request.resource.data.get('schoolId', null) == resource.data.get('schoolId', null))
          ||
          // Case 2: First-time binding of Google UID to pre-created user
          (resource.data.email == request.auth.token.email &&
           request.resource.data.email == resource.data.email &&
           request.resource.data.uid == request.auth.uid &&
           request.resource.data.role == resource.data.role &&
           request.resource.data.get('schoolId', null) == resource.data.get('schoolId', null))
          ||
          // Case 3: Principal updating a user in their school
          (isPrincipalOf(resource.data.schoolId) &&
           request.resource.data.schoolId == resource.data.schoolId &&
           (resource.data.role == 'teacher' || resource.data.role == 'student' || resource.data.role == 'parent') &&
           request.resource.data.role == resource.data.role)
        )
      );
      allow delete: if isSuperAdmin() || (
        loggedIn() && 
        isPrincipalOf(resource.data.schoolId) &&
        (resource.data.role == 'teacher' || resource.data.role == 'student' || resource.data.role == 'parent')
      );
    }
    
    // --- SCHOOLS COLLECTION ---
    match /schools/{schoolId} {
      // Members of a school can read their school info. Super Admin has full access.
      allow read: if loggedIn() && (isSuperAdmin() || getUserData().schoolId == schoolId);
      allow write: if isSuperAdmin();
    }

    // --- SUBSCRIPTIONS COLLECTION ---
    match /subscriptions/{subscriptionId} {
      allow read, write: if isSuperAdmin();
    }

    // --- OTHER FLAT COLLECTIONS (Classes, Sections, Subjects, Attendance, Homework, Materials, Exams, Marks, Fees, Leaves, Messages) ---
    // Enforce school isolation at document level using schoolId field
    match /{document=**} {
      
      // Prevent wild access to other school's documents
      allow read: if loggedIn() && (
        isSuperAdmin() || (
          resource != null && 
          resource.data.schoolId != null && 
          isSchoolMember(resource.data.schoolId)
        )
      );
      
      allow write: if loggedIn() && (
        isSuperAdmin() || (
          // For updates/deletes, ensure current document belongs to the user's school
          resource != null && 
          resource.data.schoolId != null && 
          isSchoolMember(resource.data.schoolId)
        ) || (
          // For creates, ensure incoming document has the correct schoolId matching the user's profile
          resource == null && 
          request.resource.data.schoolId != null && 
          isSchoolMember(request.resource.data.schoolId)
        )
      );
      
    }
  }
}
